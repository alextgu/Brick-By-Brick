# Copy this file to `.env.local` and fill in values locally.
# Do not commit `.env.local` (it is gitignored).
#
# Google AI Studio: https://aistudio.google.com/apikey

# Prefer server-only usage (API routes / server actions) so the key is not bundled for the browser.
GEMINI_API_KEY=

# Only if a client component must call Gemini directly (avoid when possible):
# NEXT_PUBLIC_GEMINI_API_KEY=
